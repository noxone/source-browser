# These values are baked into the bundle at build time and used only as a fallback
# when /api/config cannot be reached (e.g. standalone unit tests).
# In all normal deployments the frontend reads OIDC config from GET /api/config at
# runtime, so changing the identity provider only requires setting OIDC_AUTH_SERVER_URL
# and OIDC_CLIENT_ID on the server — no frontend rebuild needed.
VITE_OIDC_AUTHORITY=http://localhost:9090/realms/sourceviewer
VITE_OIDC_CLIENT_ID=sourceviewer-ui
